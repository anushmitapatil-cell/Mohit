<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Happy Birthday Mohit</title>

<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300&display=swap" rel="stylesheet">

<style>
body {
    margin: 0;
    padding: 0;
    background: linear-gradient(135deg, #ff9a9e, #fad0c4, #a18cd1);
    overflow: hidden;
}

/* Center Content */
.container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: white;
}

/* Title */
h1 {
    font-family: 'Great Vibes', cursive;
    font-size: 65px;
    text-shadow: 0 0 20px rgba(255,255,255,0.8);
}

/* Wishes */
p {
    font-family: 'Poppins', sans-serif;
    font-size: 20px;
    max-width: 600px;
}

/* Balloons */
.balloon {
    position: absolute;
    bottom: -100px;
    width: 60px;
    height: 80px;
    border-radius: 50%;
    opacity: 0.8;
    animation: floatUp linear infinite;
}

@keyframes floatUp {
    0% { transform: translateY(0); }
    100% { transform: translateY(-120vh); }
}

/* Ribbons */
.ribbon {
    position: absolute;
    width: 6px;
    height: 20px;
    animation: fall linear infinite;
}

@keyframes fall {
    0% { transform: translateY(-10vh) rotate(0); }
    100% { transform: translateY(110vh) rotate(360deg); }
}
</style>
</head>

<body>

<div class="container">
    <h1>HAPPIIEE HAPPIIEE<br>BIRTHDAY MOHIT 🎂</h1>
    
    <p>
    Wishing you a future filled with success, happiness, and endless smiles 💖<br><br>
    Humesha khush reh aur khoob tarakki kar aur khoob kha pii mje kar✨
    </p>
</div>

<script>
// Balloons
for(let i=0;i<20;i++){
    let b=document.createElement("div");
    b.className="balloon";
    b.style.left=Math.random()*100+"vw";
    b.style.background=["#ff6b6b","#ffd93d","#6bcBef","#b983ff"][Math.floor(Math.random()*4)];
    b.style.animationDuration=(5+Math.random()*5)+"s";
    document.body.appendChild(b);
}

// Ribbons
for(let i=0;i<50;i++){
    let r=document.createElement("div");
    r.className="ribbon";
    r.style.left=Math.random()*100+"vw";
    r.style.background=["#fff","#ff6b6b","#ffd93d","#6bcBef"][Math.floor(Math.random()*4)];
    r.style.animationDuration=(3+Math.random()*3)+"s";
    document.body.appendChild(r);
}
</script>

</body>
</html>
