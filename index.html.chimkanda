<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Happy Birthday Mohit</title>

<link href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet">

<style>
body {
    margin: 0;
    background: linear-gradient(135deg, #ff9a9e, #fad0c4, #a18cd1);
    overflow: hidden;
}

/* Text */
h1 {
    position: absolute;
    top: 40%;
    width: 100%;
    text-align: center;
    font-family: 'Pacifico', cursive;
    font-size: 60px;
    color: white;
}

/* Balloons */
.balloon {
    position: absolute;
    bottom: -100px;
    width: 50px;
    height: 70px;
    border-radius: 50%;
    animation: floatUp linear infinite;
}

@keyframes floatUp {
    100% { transform: translateY(-120vh); }
}

/* Ribbons */
.ribbon {
    position: absolute;
    width: 6px;
    height: 20px;
    animation: fall linear infinite;
}

@keyframes fall {
    100% { transform: translateY(110vh) rotate(360deg); }
}
</style>
</head>

<body>

<h1>HAPPY BIRTHDAY MOHIT 🎂</h1>

<script>
// Balloons
for(let i=0;i<15;i++){
 let b=document.createElement("div");
 b.className="balloon";
 b.style.left=Math.random()*100+"vw";
 b.style.background=["red","yellow","blue","pink"][Math.floor(Math.random()*4)];
 b.style.animationDuration=(4+Math.random()*4)+"s";
 document.body.appendChild(b);
}

// Ribbons
for(let i=0;i<30;i++){
 let r=document.createElement("div");
 r.className="ribbon";
 r.style.left=Math.random()*100+"vw";
 r.style.background=["white","pink","yellow","blue"][Math.floor(Math.random()*4)];
 r.style.animationDuration=(3+Math.random()*3)+"s";
 document.body.appendChild(r);
}
</script>

</body>
</html>
